# ===== LLM =====
OPENAI_API_KEY=sk-coloque-sua-chave-aqui
LLM_MODEL=openai:gpt-4o-mini

# ===== PostgreSQL (também usado pelo docker-compose) =====
POSTGRES_USER=atendimento
POSTGRES_PASSWORD=senha123
POSTGRES_DB=atendimento

# ===== Banco de dados (URL completa para o backend) =====
# Em dev local sem Docker: mantenha localhost
# Dentro do Docker: o compose sobrescreve para usar o hostname 'db'
DATABASE_URL=postgresql+asyncpg://atendimento:senha123@localhost:5432/atendimento

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== Logfire (opcional — observabilidade) =====
# Obtenha em: https://logfire.pydantic.dev
LOGFIRE_TOKEN=seu-token-do-logfire

# ===== Aplicação =====
APP_ENV=development
LOG_LEVEL=INFO
JWT_SECRET=minha-frase-super-secreta-com-pelo-menos-32-caracteres-aqui

# ===== Frontend =====
# URL do backend vista pelo Streamlit
# Dentro do Docker: ws://backend:8000
# Fora do Docker: ws://localhost:8000
BACKEND_URL=ws://localhost:8000
